import requests

# ---------------- SEARCH TOOL ---------------- #
def search_tool(query):
    try:
        url = f"https://api.duckduckgo.com/?q={query}&format=json"
        res = requests.get(url, timeout=10)
        data = res.json()

        answer = data.get("AbstractText")

        if not answer:
            return "No direct info found, but topic is relevant."

        return answer

    except:
        return "Search failed"


# ---------------- AGENT 1: RESEARCH ---------------- #
def research_agent(query):
    print("🔍 Research Agent working...")
    result = search_tool(query)
    return result


# ---------------- AGENT 2: SUMMARIZER ---------------- #
def summarizer_agent(text):
    print("🧠 Summarizer Agent working...")
    
    # simple summarizer (no AI API needed)
    sentences = text.split(".")
    short = sentences[0] if len(sentences) > 0 else text

    return short


# ---------------- AGENT 3: FORMATTER ---------------- #
def formatter_agent(text):
    print("✍️ Formatter Agent working...")

    return f"""
========================
📌 FINAL ANSWER
========================

{text}

========================
Generated by Multi-Agent System
========================
"""


# ---------------- WORKFLOW ENGINE ---------------- #
def multi_agent_system(query):

    step1 = research_agent(query)
    step2 = summarizer_agent(step1)
    final = formatter_agent(step2)

    return final


# ---------------- CHAT LOOP ---------------- #
print("🤖 Multi-Agent System Started (type 'exit' to stop)\n")

while True:
    user = input("You: ")

    if user.lower() == "exit":
        print("Bye 👋")
        break

    response = multi_agent_system(user)
    print(response)